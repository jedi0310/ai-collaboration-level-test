name = "ai-test-deepseek-proxy"
main = "worker.js"
compatibility_date = "2026-06-18"

# Do not put real API keys, tokens, or account IDs in this file.
# Configure DEEPSEEK_API_KEY and ADMIN_TOKEN as Worker secrets in Cloudflare.

[[d1_databases]]
binding = "DB"
database_name = "ai-test-reports"
database_id = "<your-d1-database-id>"
